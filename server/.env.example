# Copy to .env and adjust
PORT=5000
MONGO_URI=mongodb://localhost:27017/propertyfinder
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# SMTP for password-reset codes (was PHPMailer/Gmail in the PHP app)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=propertyfinder428@gmail.com
SMTP_PASS=your-gmail-app-password
MAIL_FROM_NAME=CedarHomes

# Used only by scripts/migrate.js to read the legacy database
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=project
LEGACY_ROOT=../..
