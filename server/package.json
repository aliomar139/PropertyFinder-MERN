{
  "name": "propertyfinder-server",
  "version": "1.0.0",
  "description": "PropertyFinder REST API (migrated from PHP/MySQL)",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "migrate": "node scripts/migrate.js",
    "seed": "node scripts/seed.js",
    "export-data": "node scripts/export-data.js",
    "import-data": "node scripts/import-data.js",
    "smoke": "npm install mongodb-memory-server --no-save && node scripts/smoke-test.mjs"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.4.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.13"
  },
  "optionalDependencies": {
    "mysql2": "^3.10.0"
  }
}
